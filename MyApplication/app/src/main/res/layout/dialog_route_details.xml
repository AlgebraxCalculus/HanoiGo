<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="24dp"
        app:cardUseCompatPadding="false"
        app:cardBackgroundColor="@color/explore_card_bg">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Header: icon + title -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/ivRouteIcon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_location"
                    android:tint="@android:color/white"
                    android:contentDescription="@null" />

                <TextView
                    android:id="@+id/tvRouteTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="Route title"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="@android:color/white" />
            </LinearLayout>

            <!-- Tổng quãng đường + thời gian -->
            <TextView
                android:id="@+id/tvRouteSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Total: 0.0 km • 0m"
                android:textSize="13sp"
                android:textColor="#B3FFFFFF" />

            <!-- Divider mảnh, mềm -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp"
                android:background="#33FFFFFF" />

            <!-- Danh sách stops (scroll nếu dài) -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRouteStops"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:nestedScrollingEnabled="true"
                android:clipToPadding="false"
                android:paddingBottom="8dp" />

            <!-- Nút đóng -->
            <Button
                android:id="@+id/btnCloseRoute"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Close"
                android:textAllCaps="false"
                android:backgroundTint="@color/explore_primary"
                android:textColor="@android:color/white" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</FrameLayout>
