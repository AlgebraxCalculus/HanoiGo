<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/swipeRefreshLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:background="#081A2B"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:gravity="center_vertical">

            <FrameLayout
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_circle_with_border"
                android:padding="1dp"
                android:translationZ="1dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:clipToOutline="true"
                    android:background="@drawable/bg_circle"
                    android:src="@drawable/logo"/>
            </FrameLayout>

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="Personal"
                    android:textColor="@android:color/white"
                    android:textSize="30sp"
                    android:textStyle="bold"
                    android:layout_marginStart="13dp" />
            </FrameLayout>

            <LinearLayout
                android:id="@+id/rightIcons"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

<!--                <ImageView-->
<!--                    android:id="@+id/icBell"-->
<!--                    android:layout_width="24dp"-->
<!--                    android:layout_height="24dp"-->
<!--                    android:src="@drawable/ic_notification_24"-->
<!--                    app:tint="@android:color/white"-->
<!--                    android:layout_marginEnd="16dp" />-->

                <ImageView
                    android:id="@+id/icSettings"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_settings_24"
                    app:tint="@android:color/white" />
            </LinearLayout>
        </LinearLayout>

        <androidx.core.widget.NestedScrollView
            android:id="@+id/scrollView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@android:color/white">

                <!-- User Stats Section -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <!-- Background Image -->
                    <ImageView
                        android:id="@+id/imgBackgroundProfile"
                        android:layout_width="match_parent"
                        android:layout_height="140dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/siuuuu_bg"
                        android:background="#1A1A1A" />

                    <!-- White Container for User Info -->
                    <LinearLayout
                        android:id="@+id/containerUserInfo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/imgBackgroundProfile"
                        android:orientation="horizontal"
                        android:background="#FFFFFF"
                        android:paddingTop="40dp"
                        android:paddingBottom="25dp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <!-- User Name and Stats -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="0dp">

                            <!-- User Name -->
                            <TextView
                                android:id="@+id/tvUserName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Đỗ Trung Quân"
                                android:textColor="#000000"
                                android:textSize="20sp"
                                android:textStyle="bold" />

                            <!-- Stats Container -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginTop="8dp">

                                <!-- Points Stat -->
                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:layout_marginEnd="16dp">

                                    <ImageView
                                        android:layout_width="20dp"
                                        android:layout_height="20dp"
                                        android:src="@drawable/ic_points"/>

                                    <TextView
                                        android:id="@+id/tvPoints"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="1236"
                                        android:textColor="#000000"
                                        android:textSize="16sp"
                                        android:textStyle="bold"
                                        android:layout_marginStart="4dp" />
                                </LinearLayout>

                                <!-- Rank Stat -->
                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical">

                                    <ImageView
                                        android:layout_width="20dp"
                                        android:layout_height="20dp"
                                        android:src="@drawable/ic_rank"/>

                                    <TextView
                                        android:id="@+id/tvRank"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="1st"
                                        android:textColor="#000000"
                                        android:textSize="16sp"
                                        android:textStyle="bold"
                                        android:layout_marginStart="4dp" />
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Avatar chồm lên cả background và white container -->
                    <FrameLayout
                        android:layout_width="96dp"
                        android:layout_height="96dp"
                        android:layout_alignBottom="@id/imgBackgroundProfile"
                        android:layout_marginBottom="-25dp"
                        android:layout_marginStart="16dp"
                        android:background="@drawable/bg_circle_with_border"
                        android:padding="3dp"
                        android:elevation="8dp">

                        <ImageView
                            android:id="@+id/imgUserAvatar"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:clipToOutline="true"
                            android:background="@drawable/bg_circle"
                            android:src="@drawable/avatar"/>
                    </FrameLayout>

                </RelativeLayout>

                <!-- Navigation Bar -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#1B1B1B" />

                <LinearLayout
                    android:id="@+id/navBar"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:orientation="horizontal"
                    android:background="#FFFFFF"
                    android:elevation="2dp">



                    <!-- Progress Tab -->
                    <LinearLayout
                        android:id="@+id/tabProgress"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_nav_left_active"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:id="@+id/imgProgress"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_trending_up"
                            app:tint="#FFFFFF" />

                        <TextView
                            android:id="@+id/tvProgress"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Progress"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <!-- Achievements Tab -->
                    <LinearLayout
                        android:id="@+id/tabAchievements"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_nav_center_inactive"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:id="@+id/imgAchievements"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/medal_ic"
                            app:tint="#1B1B1B" />

                        <TextView
                            android:id="@+id/tvAchievements"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Achievements"
                            android:textColor="#1B1B1B"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <!-- Checkpoints Tab -->
                    <LinearLayout
                        android:id="@+id/tabCheckpoints"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_nav_right_inactive"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:id="@+id/imgCheckpoints"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_location"
                            app:tint="#1B1B1B" />

                        <TextView
                            android:id="@+id/tvCheckpoints"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Checkpoints"
                            android:textColor="#1B1B1B"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </LinearLayout>
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#1B1B1B" />

                <!-- Content Area -->
                <FrameLayout
                    android:id="@+id/contentContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="200dp"
                    android:clipToPadding="false"
                    android:clipChildren="false"/>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </LinearLayout>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>