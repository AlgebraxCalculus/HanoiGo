<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#111"
    android:padding="12dp"
    android:layout_marginBottom="12dp"
    android:clipToOutline="true"
    android:elevation="2dp"
    android:backgroundTintMode="add">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/imgAvatar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/avatar"
            android:scaleType="centerCrop"
            android:background="@drawable/bg_round"
            android:clipToOutline="true"
            android:layout_marginEnd="8dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Lmao123"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Local Guide - 300 reviews"
                android:textColor="#ccc"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Rating + time -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="6dp"
        android:gravity="center_vertical">

        <RatingBar
            android:id="@+id/ratingBar"
            style="?android:attr/ratingBarStyleSmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:numStars="5"
            android:stepSize="0.5"
            android:layout_marginTop="4dp"
            android:scaleX="0.8"
            android:scaleY="0.8"
            android:isIndicator="true"
            android:progressTint="@color/gold"
            android:secondaryProgressTint="@color/gold"
            android:indeterminateTint="@color/gold"/>


        <TextView
            android:id="@+id/tvTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="• a week ago"
            android:textColor="#ccc"
            android:textSize="12sp"
            android:layout_marginStart="6dp" />
    </LinearLayout>

    <!-- Nội dung review -->
    <com.colormoon.readmoretextview.ReadMoreTextView
        android:id="@+id/tvContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:layout_gravity="center"
        android:text="@string/review_text_sample"
        android:textColor="#ddd"
        android:textSize="14sp" />

    <!-- Grid hình ảnh -->
    <GridLayout
        android:id="@+id/imageGrid"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:rowCount="2"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">
    </GridLayout>

    <!-- Like -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="start"
        android:layout_marginTop="6dp">

        <ImageView
            android:id="@+id/btnLike"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_thumb_up"
            app:tint="#ccc" />

        <TextView
            android:id="@+id/tvLikeCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="4"
            android:textColor="#ccc"
            android:layout_marginStart="4dp"/>
    </LinearLayout>
</LinearLayout>
