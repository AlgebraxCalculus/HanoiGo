<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/placeDetailContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/bottomSheetPlaceDetail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginBottom="100dp"
        android:background="@drawable/bg_bottom_sheet"
        android:clickable="true"
        android:focusable="true"
        app:behavior_hideable="false"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">
        <LinearLayout
            android:id="@+id/placeDetailRoot"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp">

            <!-- Drag handle -->
            <View
                android:layout_width="40dp"
                android:layout_height="4dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_drag_handle" />

            <!-- Tiêu đề và thông tin -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="8dp">

                <TextView
                    android:id="@+id/placeTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Hoan Kiem Lake"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF" />

                <ImageView
                    android:id="@+id/btnCloseExplore"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_close"
                    android:contentDescription="Close" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/ratingRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="2dp"
                android:layout_marginStart="9dp">

                <!-- Số điểm (màu xám) -->
                <TextView
                    android:id="@+id/tvRatingNumber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="4,5"
                    android:textSize="14sp"
                    android:textColor="#BBBBBB"
                    android:layout_marginEnd="6dp"/>

                <!-- RatingBar: hỗ trợ half-star -->
                <androidx.appcompat.widget.AppCompatRatingBar
                    android:id="@+id/ratingBar"
                    style="@style/Widget.AppCompat.RatingBar.Small"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:numStars="5"
                    android:stepSize="0.5"
                    android:rating="4.5"
                    android:isIndicator="true"
                    android:layout_marginEnd="8dp"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="2dp"
                    android:scaleX="1.0"
                    android:scaleY="1.0"
                    android:padding="0dp"
                    android:layout_gravity="center_vertical"
                    android:progressTint="@color/gold"
                    android:secondaryProgressTint="@color/gold"
                    android:indeterminateTint="@color/gold"
                    android:progressBackgroundTint="#FFFFFF" />

                <!-- Số review + khoảng cách (màu xám) -->
                <TextView
                    android:id="@+id/tvRatingMeta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="(10) • 1,5 km"
                    android:textSize="13sp"
                    android:textColor="#BBBBBB"/>
            </LinearLayout>

            <TextView
                android:id="@+id/placeAddress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hang Trong, Hoàn Kiếm, Hanoi, Vietnam"
                android:textColor="#BBBBBB"
                android:textSize="13sp"
                android:layout_marginStart="9dp"
                android:layout_marginBottom="2dp"/>

            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:gravity="center_vertical"
                android:layout_marginStart="9dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_bike"
                    android:layout_marginEnd="4dp"
                    app:tint="#AAAAAA" />

                <TextView
                    android:id="@+id/placeTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="20 minutes"
                    android:textColor="#AAAAAA"
                    android:textSize="13sp"/>
            </LinearLayout>

            <!-- Nút hành động -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDirections"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Directions"
                    android:textColor="#000C17"
                    app:backgroundTint="#01B8B3"
                    app:cornerRadius="20dp"
                    app:icon="@drawable/ic_direction"
                    app:iconTint="#000C17"
                    app:iconPadding="6dp"
                    app:iconGravity="textStart"

                    app:iconSize="20dp"

                    style="@style/Widget.MaterialComponents.Button"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSave"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Save"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="#1E3D34"

                    app:icon="@drawable/ic_save"
                    app:iconTint="#FFFFFF"
                    app:iconSize="20dp"
                    app:iconPadding="6dp"
                    app:iconGravity="textStart"

                    app:cornerRadius="20dp"
                    android:layout_marginStart="12dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    style="@style/Widget.MaterialComponents.Button.TextButton"/>
            </LinearLayout>
            <!-- Photos Section -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvPlacePhotos"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                android:layout_marginBottom="16dp"
                android:overScrollMode="never"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"/>

            <!-- Overall Section -->
            <TextView
                android:id="@+id/overallTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Overall"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="20sp"
                android:fontFamily="@font/poppins_semibold" />

            <!-- Description Box -->
            <TextView
                android:id="@+id/overallDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:padding="12dp"
                android:background="@drawable/bg_overall_box"
                android:text="Lake featuring a temple on a small island reached via a wooden bridge and a tower on another island."
                android:textColor="#CCCCCC"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp" />

            <!-- Location Box -->
            <LinearLayout
                android:id="@+id/locationContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_overall_box"
                android:padding="12dp">

                <ImageView
                    android:id="@+id/iconLocation"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_location"
                    android:contentDescription="location icon"
                    app:tint="#FFFFFF" />

                <TextView
                    android:id="@+id/locationText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Hang Trong, Hoàn Kiếm, Hanoi, Vietnam"
                    android:textColor="#CCCCCC"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Reviews Summary Section -->
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#1E1E1E"
                android:padding="12dp"
                android:layout_marginBottom="16dp"
                android:layout_marginTop="8dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Reviews summary"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:layout_marginBottom="16dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp"
                    android:baselineAligned="false">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginEnd="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="4,7"
                            android:textColor="#FFFFFF"
                            android:textSize="48sp"
                            android:textStyle="bold"
                            android:lineSpacingExtra="-8dp"
                            android:layout_marginBottom="-4dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="★★★★★"
                            android:textColor="#FFD700"
                            android:textSize="20sp"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="(11.291)"
                            android:textColor="#CCCCCC"
                            android:textSize="14sp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <include layout="@layout/item_rating_bar_line" android:id="@+id/ratingBar5" />
                        <include layout="@layout/item_rating_bar_line" android:id="@+id/ratingBar4" />
                        <include layout="@layout/item_rating_bar_line" android:id="@+id/ratingBar3" />
                        <include layout="@layout/item_rating_bar_line" android:id="@+id/ratingBar2" />
                        <include layout="@layout/item_rating_bar_line" android:id="@+id/ratingBar1" />

                    </LinearLayout>
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnWriteReview"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Write a review"
                    android:textColor="#000C17"
                    app:backgroundTint="#01B8B3"
                    app:cornerRadius="20dp"
                    app:icon="@drawable/ic_edit_note"
                    app:iconTint="#000C17"
                    app:iconPadding="6dp"
                    app:iconGravity="textStart"

                    app:iconSize="20dp"

                    style="@style/Widget.MaterialComponents.Button"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:layout_gravity="center_horizontal"/>

            </LinearLayout>

            <!-- Search bar -->
            <androidx.cardview.widget.CardView
                android:id="@+id/searchContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@android:color/transparent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="8dp"
                    android:background="@drawable/bg_review_searchbar">

                    <ImageView
                        android:id="@+id/searchIcon"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/routing"
                        android:contentDescription="@string/desc_search_icon" />

                    <EditText
                        android:id="@+id/searchBar"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="@string/hint_review_search"
                        android:imeOptions="actionSearch"
                        android:inputType="text"
                        android:singleLine="true"
                        android:ellipsize="end"
                        android:paddingHorizontal="8dp"
                        android:textColor="@android:color/white"
                        android:textColorHint="@android:color/black"
                        android:textSize="16sp" />

                    <ImageView
                        android:id="@+id/actionButton"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_search"
                        android:scaleType="centerCrop"
                        android:background="@drawable/bg_round"
                        android:clipToOutline="true" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Tag filter -->
            <HorizontalScrollView
                android:id="@+id/tagScrollView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:scrollbars="none"
                android:overScrollMode="never">

                <LinearLayout
                    android:id="@+id/tagContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="8dp">

                    <TextView style="@style/TagStyle" android:text="@string/tag_most_approved" />
                    <TextView style="@style/TagStyle" android:layout_marginStart="8dp" android:text="@string/tag_newest" />
                    <TextView style="@style/TagStyle" android:layout_marginStart="8dp" android:text="@string/tag_highest_rate" />
                    <TextView style="@style/TagStyle" android:layout_marginStart="8dp" android:text="@string/tag_lowest_rate" />
                </LinearLayout>
            </HorizontalScrollView>
            <!-- Reviews List -->
            <androidx.recyclerview.widget.RecyclerView
                xmlns:android="http://schemas.android.com/apk/res/android"
                android:id="@+id/rvReviews"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="12dp"
                android:clipToPadding="false"
                android:background="#000"/>

            <!-- Khoảng trống cuối -->
            <View
                android:layout_width="match_parent"
                android:layout_height="150dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>