<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/placeDetailContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <!-- BOTTOM SHEET CONTAINER -->
    <LinearLayout
        android:id="@+id/bottomSheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_bottom_sheet">

    <!-- ⭐ GOOGLE MAPS STYLE HEADER (có thể cố định khi kéo lên) -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/placeHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_bottom_sheet"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="8dp"
        app:liftOnScroll="true">

        <!-- Drag handle -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_drag_handle" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:padding="8dp"
            app:layout_scrollFlags="scroll|enterAlwaysCollapsed">

            <TextView
                android:id="@+id/placeTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Hoan Kiem Lake"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"/>

            <ImageView
                android:id="@+id/btnCloseExplore"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_close"/>
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- ⭐ NỘI DUNG CÓ THỂ CUỘN -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:fillViewport="true">

        <!-- 100% phần còn lại giữ nguyên -->
        <LinearLayout
            android:id="@+id/placeDetailRoot"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="8dp"
            android:paddingBottom="8dp"
            android:paddingEnd="8dp">

            <LinearLayout
                android:id="@+id/ratingRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="2dp"
                android:layout_marginStart="9dp">

                <!-- Số điểm (màu xám) -->
                <TextView
                    android:id="@+id/tvRatingNumber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="4,5"
                    android:textSize="14sp"
                    android:textColor="#BBBBBB"
                    android:layout_marginEnd="6dp"/>

                <!-- RatingBar: hỗ trợ half-star -->
                <androidx.appcompat.widget.AppCompatRatingBar
                    android:id="@+id/ratingBar"
                    style="@style/Widget.AppCompat.RatingBar.Small"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:numStars="5"
                    android:stepSize="0.5"
                    android:rating="4.5"
                    android:isIndicator="true"
                    android:layout_marginEnd="8dp"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="2dp"
                    android:scaleX="1.0"
                    android:scaleY="1.0"
                    android:padding="0dp"
                    android:layout_gravity="center_vertical"
                    android:progressTint="@color/gold"
                    android:secondaryProgressTint="@color/gold"
                    android:indeterminateTint="@color/gold"
                    android:progressBackgroundTint="#FFFFFF" />

                    <!-- Số review -->
                    <TextView
                        android:id="@+id/tvReviewCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="(10)"
                        android:textSize="13sp"
                        android:textColor="#BBBBBB"/>
            </LinearLayout>

            <TextView
                android:id="@+id/placeAddress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hang Trong, Hoàn Kiếm, Hanoi, Vietnam"
                android:textColor="#BBBBBB"
                android:textSize="13sp"
                android:layout_marginStart="9dp"
                android:layout_marginBottom="2dp"/>

            <!-- Nút hành động -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:overScrollMode="never"
                android:layout_marginBottom="16dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCheckin"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Check-in"
                        android:textColor="#000C17"
                        app:backgroundTint="#EEB536"
                        app:cornerRadius="20dp"
                        app:icon="@drawable/ic_checkpoint"
                        app:iconTint="#000C17"
                        app:iconPadding="6dp"
                        app:iconGravity="textStart"
                        app:iconSize="20dp"
                        style="@style/Widget.MaterialComponents.Button"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDirections"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Directions"
                        android:textColor="#000C17"
                        app:backgroundTint="#01B8B3"
                        app:cornerRadius="20dp"
                        app:icon="@drawable/ic_direction"
                        app:iconTint="#000C17"
                        app:iconPadding="6dp"
                        app:iconGravity="textStart"
                        app:iconSize="20dp"
                        style="@style/Widget.MaterialComponents.Button"
                        android:layout_marginStart="8dp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSave"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Save"
                        android:textColor="#FFFFFF"
                        app:backgroundTint="#1E3D34"
                        app:icon="@drawable/ic_save"
                        app:iconTint="#FFFFFF"
                        app:iconSize="20dp"
                        app:iconPadding="6dp"
                        app:iconGravity="textStart"
                        app:cornerRadius="20dp"
                        android:layout_marginStart="8dp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        style="@style/Widget.MaterialComponents.Button.TextButton" />
                </LinearLayout>
            </HorizontalScrollView>
            <!-- Photos Section -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvPlacePhotos"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                android:layout_marginBottom="16dp"
                android:overScrollMode="never"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"/>

            <!-- Overall Section -->
            <TextView
                android:id="@+id/overallTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Overall"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="20sp"
                android:fontFamily="@font/poppins_semibold" />

            <!-- Description Box -->
            <TextView
                android:id="@+id/overallDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:padding="12dp"
                android:background="@drawable/bg_overall_box"
                android:text="Lake featuring a temple on a small island reached via a wooden bridge and a tower on another island."
                android:textColor="#CCCCCC"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp" />

            <!-- Location Box -->
            <LinearLayout
                android:id="@+id/locationContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_overall_box"
                android:padding="12dp">

                <ImageView
                    android:id="@+id/iconLocation"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_location"
                    android:contentDescription="location icon"
                    app:tint="#FFFFFF" />

                <TextView
                    android:id="@+id/locationText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Hang Trong, Hoàn Kiếm, Hanoi, Vietnam"
                    android:textColor="#CCCCCC"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Reviews Summary Section -->
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:layout_marginBottom="16dp"
                android:layout_marginTop="8dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Reviews summary"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:layout_marginBottom="16dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp"
                    android:baselineAligned="false">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginEnd="16dp">

                        <TextView
                            android:id="@+id/tvOverallRating"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="4,7"
                            android:textColor="#FFFFFF"
                            android:textSize="48sp"
                            android:textStyle="bold"
                            android:lineSpacingExtra="-8dp"
                            android:layout_marginBottom="-4dp"/>

                        <RatingBar
                            android:id="@+id/rtOverallRatingBar"
                            style="?android:attr/ratingBarStyleSmall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:numStars="5"
                            android:stepSize="0.5"
                            android:isIndicator="true"
                            android:progressTint="@color/gold"
                            android:secondaryProgressTint="@color/gold"
                            android:indeterminateTint="@color/gold"
                            android:layout_gravity="center_vertical"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:id="@+id/tvOverallRatingCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="(11.291)"
                            android:textColor="#CCCCCC"
                            android:textSize="14sp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <include layout="@layout/item_rating_bar_line" android:id="@+id/ratingBar5" />
                        <include layout="@layout/item_rating_bar_line" android:id="@+id/ratingBar4" />
                        <include layout="@layout/item_rating_bar_line" android:id="@+id/ratingBar3" />
                        <include layout="@layout/item_rating_bar_line" android:id="@+id/ratingBar2" />
                        <include layout="@layout/item_rating_bar_line" android:id="@+id/ratingBar1" />

                    </LinearLayout>
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnWriteReview"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Write a review"
                    android:textColor="#000C17"
                    app:backgroundTint="#01B8B3"
                    app:cornerRadius="20dp"
                    app:icon="@drawable/ic_edit_note"
                    app:iconTint="#000C17"
                    app:iconPadding="6dp"
                    app:iconGravity="textStart"
                    app:iconSize="20dp"
                    style="@style/Widget.MaterialComponents.Button"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:layout_gravity="center_horizontal"/>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/yourReview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="-20dp"
                android:padding="12dp"
                android:layout_marginBottom="12dp"
                android:clipToOutline="true"
                android:elevation="2dp"
                android:backgroundTintMode="add">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Your review:"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:textSize="20sp"
                    android:layout_marginBottom="12dp"
                    android:layout_marginTop="-8dp"/>

                <!-- Header -->

                <!-- Rating + time -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/imgYourAvatar"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_round"
                        android:clipToOutline="true"
                        android:scaleType="centerCrop"
                        android:src="@drawable/avatar" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvYourName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Lmao123"
                            android:textColor="@android:color/white"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvSubtitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Local Guide"
                            android:textColor="#ccc"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="6dp"
                    android:gravity="center_vertical">

                    <RatingBar
                        android:id="@+id/yourRatingBar"
                        style="?android:attr/ratingBarStyleSmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:numStars="5"
                        android:stepSize="0.5"
                        android:scaleX="0.8"
                        android:scaleY="0.8"
                        android:layout_marginStart="-8dp"
                        android:isIndicator="true"
                        android:progressTint="@color/gold"
                        android:secondaryProgressTint="@color/gold"
                        android:indeterminateTint="@color/gold"
                        android:layout_gravity="center_vertical"/>


                    <TextView
                        android:id="@+id/tvYourTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="• a week ago"
                        android:textColor="#ccc"
                        android:textSize="12sp"
                        android:layout_marginStart="6dp" />
                </LinearLayout>

                <!-- Nội dung review -->
                <com.colormoon.readmoretextview.ReadMoreTextView
                    android:id="@+id/tvYourContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_gravity="center"
                    android:text="@string/review_text_sample"
                    android:textColor="#ddd"
                    android:textSize="14sp" />

                <!-- Grid hình ảnh -->
                <GridLayout
                    android:id="@+id/yourImageGrid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:rowCount="2"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">
                </GridLayout>

                <!-- Like -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="start"
                    android:layout_marginTop="10dp">

                    <ImageView
                        android:id="@+id/btnYourLike"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_thumb_up"
                        app:tint="#ccc" />

                    <TextView
                        android:id="@+id/tvYourLikeCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="4"
                        android:textColor="#ccc"
                        android:layout_marginStart="4dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_gravity="center"
                    android:layout_marginTop="6dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnUpdateReview"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Update"
                        android:textColor="#000C17"
                        app:backgroundTint="#fae457"
                        app:cornerRadius="20dp"
                        app:icon="@drawable/ic_edit_note"
                        app:iconTint="#000C17"
                        app:iconPadding="6dp"
                        app:iconGravity="textStart"
                        app:iconSize="20dp"
                        style="@style/Widget.MaterialComponents.Button"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:layout_marginStart="40dp"
                        android:layout_gravity="center_vertical"/>

                    <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDeleteReview"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Delete"
                        android:textColor="#000C17"
                        app:backgroundTint="#fa3939"
                        app:cornerRadius="20dp"
                        app:icon="@drawable/ic_edit_note"
                        app:iconTint="#000C17"
                        app:iconPadding="6dp"
                        app:iconGravity="textStart"
                        app:iconSize="20dp"
                        style="@style/Widget.MaterialComponents.Button"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:layout_marginEnd="40dp"
                        android:layout_gravity="center_vertical"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Search bar -->
            <androidx.cardview.widget.CardView
                android:id="@+id/searchContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@android:color/transparent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="8dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_review_searchbar">

                    <ImageView
                        android:id="@+id/searchIcon"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/routing"
                        android:contentDescription="@string/desc_search_icon" />

                    <EditText
                        android:id="@+id/searchBar"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="@string/hint_review_search"
                        android:imeOptions="actionSearch"
                        android:inputType="text"
                        android:singleLine="true"
                        android:ellipsize="end"
                        android:paddingHorizontal="8dp"
                        android:textColor="@android:color/black"
                        android:textColorHint="@android:color/black"
                        android:textSize="16sp" />

                    <ImageView
                        android:id="@+id/actionButton"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_search"
                        android:scaleType="centerCrop"
                        android:background="@drawable/bg_round"
                        android:clipToOutline="true" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Tag filter -->
            <HorizontalScrollView
                android:id="@+id/tagScrollView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:scrollbars="none"
                android:overScrollMode="never">

                <LinearLayout
                    android:id="@+id/tagContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="8dp">

                    <TextView style="@style/TagStyle" android:text="@string/tag_most_approved" />
                    <TextView style="@style/TagStyle" android:layout_marginStart="8dp" android:text="@string/tag_newest" />
                    <TextView style="@style/TagStyle" android:layout_marginStart="8dp" android:text="@string/tag_highest_rate" />
                    <TextView style="@style/TagStyle" android:layout_marginStart="8dp" android:text="@string/tag_lowest_rate" />
                </LinearLayout>
            </HorizontalScrollView>
            <!-- Reviews List -->
            <androidx.recyclerview.widget.RecyclerView
                xmlns:android="http://schemas.android.com/apk/res/android"
                android:id="@+id/rvReviews"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="12dp"
                android:clipToPadding="false"
                />

            <LinearLayout
                android:id="@+id/layoutNoReview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="24dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvNoReview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No reviews founded!"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:padding="16dp" />

                <ImageView
                    android:id="@+id/imgNoReview"
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:src="@drawable/ic_no_achievement_sad_face"
                    android:layout_gravity="center"
                    android:alpha="0.9" />
            </LinearLayout>
            <View
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="300dp" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>

    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>