<?xml version="1.0" encoding="utf-8"?>
<!-- File: res/layout/item_pers_checkpoint.xml -->
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Place Image with overlay info -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="250dp">

            <!-- Place Image -->
            <ImageView
                android:id="@+id/ivPlaceImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:contentDescription="Place image"/>

            <!-- Gradient Overlay -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/gradient_overlay_bottom" />

            <!-- Place Info Overlay -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Place Name -->
                <TextView
                    android:id="@+id/tvPlaceName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hoan Kiem lake"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:shadowColor="#80000000"
                    android:shadowRadius="4"
                    android:shadowDx="0"
                    android:shadowDy="2" />

                <!-- Description and Date/Time Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp"
                    android:gravity="center_vertical">

                    <!-- Place Description -->
                    <TextView
                        android:id="@+id/tvPlaceDescription"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="description bla bla bla bla bla bla bla bla bla"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:maxLines="2"
                        android:ellipsize="end"
                        android:shadowColor="#80000000"
                        android:shadowRadius="4"
                        android:shadowDx="0"
                        android:shadowDy="2"
                        android:layout_marginEnd="30dp" />

                    <!-- Date and Time -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="end">

                        <TextView
                            android:id="@+id/tvCheckpointDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="09/09/2025"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"
                            android:shadowColor="#80000000"
                            android:shadowRadius="4"
                            android:shadowDx="0"
                            android:shadowDy="2" />

                        <TextView
                            android:id="@+id/tvCheckpointTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="14:30:00"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"
                            android:shadowColor="#80000000"
                            android:shadowRadius="4"
                            android:shadowDx="0"
                            android:shadowDy="2" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>

        <!-- Review Section - Has Review -->
        <LinearLayout
            android:id="@+id/layoutHasReview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="#000000"
            android:visibility="visible"
            android:clipToPadding="false"
            android:clipChildren="false">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your review"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <!-- Star Rating -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:id="@+id/layoutStars"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/star1"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_star_filled"
                        app:tint="#FFC107"
                        android:layout_marginEnd="2dp" />

                    <ImageView
                        android:id="@+id/star2"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_star_filled"
                        app:tint="#FFC107"
                        android:layout_marginEnd="2dp" />

                    <ImageView
                        android:id="@+id/star3"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_star_filled"
                        app:tint="#FFC107"
                        android:layout_marginEnd="2dp" />

                    <ImageView
                        android:id="@+id/star4"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_star_filled"
                        app:tint="#FFC107"
                        android:layout_marginEnd="2dp" />

                    <ImageView
                        android:id="@+id/star5"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_star_filled"
                        app:tint="#FFC107" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvReviewTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="few seconds ago"
                    android:textColor="#CCCCCC"
                    android:textSize="12sp"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <!-- Review Content -->
            <TextView
                android:id="@+id/tvReviewContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat."
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:maxLines="4"
                android:ellipsize="end"
                android:layout_marginBottom="16dp" />

            <!-- View Full Review Button -->
            <TextView
                android:id="@+id/btnViewFullReview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="View full review"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/bg_bottom_button_review"
                android:padding="14dp"
                android:layout_marginBottom="-16dp"
                android:layout_marginStart="-16dp"
                android:layout_marginEnd="-16dp"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- Review Section - No Review -->
        <LinearLayout
            android:id="@+id/layoutNoReview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="#000000"
            android:visibility="gone"
            android:clipToPadding="false"
            android:clipChildren="false">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="You haven't post your review yet"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Write your review now to earn up to 10 points"
                android:textColor="#CCCCCC"
                android:textSize="12sp"
                android:layout_marginBottom="16dp" />

            <!-- Write Your Review Button -->
            <TextView
                android:id="@+id/btnWriteReview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Write your review"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/bg_bottom_button_review"
                android:padding="14dp"
                android:layout_marginBottom="-16dp"
                android:layout_marginStart="-16dp"
                android:layout_marginEnd="-16dp"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>