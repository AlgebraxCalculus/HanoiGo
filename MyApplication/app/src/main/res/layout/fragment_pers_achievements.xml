<?xml version="1.0" encoding="utf-8"?>
<!-- File: res/layout/fragment_pers_achievements.xml -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Header with count -->
    <TextView
        android:id="@+id/tvAchievementCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0 Achievement"
        android:textColor="#000000"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_margin="16dp" />

    <!-- Search Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/bg_search_bar"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_medal"
            android:layout_marginEnd="12dp" />

        <EditText
            android:id="@+id/etSearchAchievement"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Search achievement by name"
            android:textColorHint="#999999"
            android:textColor="#000000"
            android:textSize="14sp"
            android:background="@null"
            android:inputType="text"
            android:imeOptions="actionSearch" />

        <ImageView
            android:id="@+id/ivSearch"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_search"
            app:tint="#666666" />
    </LinearLayout>

    <!-- Horizontal Filter ScrollView -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <!-- Highest rate Filter -->
            <TextView
                android:id="@+id/filterHighestTier"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Highest tier"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:background="@drawable/bg_filter_selected"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true" />

            <!-- Newest Filter -->
            <TextView
                android:id="@+id/filterNewest"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Newest"
                android:textColor="#000000"
                android:textSize="12sp"
                android:background="@drawable/bg_filter_unselected"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true" />

            <!-- Lowest tier Filter -->
            <TextView
                android:id="@+id/filterLowestTier"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="lowest tier"
                android:textColor="#000000"
                android:textSize="12sp"
                android:background="@drawable/bg_filter_unselected"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true" />

            <!-- Oldest Filter -->
            <TextView
                android:id="@+id/filterOldest"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Oldest"
                android:textColor="#000000"
                android:textSize="12sp"
                android:background="@drawable/bg_filter_unselected"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- RecyclerView for Achievements -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvAchievements"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:clipToPadding="false" />

    <LinearLayout
        android:id="@+id/layoutNoAchievements"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvNoAchievements"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No achievements found!"
            android:textColor="#000000"
            android:gravity="center"
            android:textSize="15dp"
            android:textStyle="bold"
            android:padding="16dp" />

        <ImageView
            android:id="@+id/imgNoAchievements"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:src="@drawable/ic_no_achievement_sad_face"
            android:layout_gravity="center"
            android:alpha="0.9" />
    </LinearLayout>

</LinearLayout>