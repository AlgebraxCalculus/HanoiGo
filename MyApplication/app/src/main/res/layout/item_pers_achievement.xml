<?xml version="1.0" encoding="utf-8"?>
<!-- File: res/layout/item_pers_achievement.xml -->
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Achievement Badge Icon -->
        <FrameLayout
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginEnd="16dp">

            <!-- Badge Background with rounded corners -->
            <View
                android:id="@+id/badgeBackground"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_tier_sss" />

            <!-- Badge Icon -->
            <ImageView
                android:id="@+id/ivBadgeIcon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_medal"/>
        </FrameLayout>

        <!-- Achievement Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvAchievementTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Legend on the Rise"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvAchievementDescription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reach top 10"
                android:textColor="#666666"
                android:textSize="12sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Right side: Date and Tier Badge -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tvAchievementDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="mm/DD/yyyy"
                android:textColor="#999999"
                android:textSize="12sp"
                android:layout_marginBottom="8dp" />

            <!-- Tier Badge -->
            <TextView
                android:id="@+id/tvTierBadge"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_tier_sss"
                android:padding="4dp"
                android:minWidth="48dp"
                android:gravity="center" />
        </LinearLayout>
    </LinearLayout>

</androidx.cardview.widget.CardView>