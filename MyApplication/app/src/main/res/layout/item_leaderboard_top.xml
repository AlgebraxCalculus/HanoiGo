<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:layout_marginHorizontal="12dp">

    <FrameLayout
        android:id="@+id/frameAvatarContainer"
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:gravity="center">

        <View
            android:id="@+id/viewBorder"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="4dp"/>

        <!-- Ảnh đại diện -->
        <ImageView
            android:id="@+id/imgAvatarTop"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/ic_user"
            android:scaleType="centerCrop"
            android:layout_gravity="center" />

        <!-- Số thứ hạng trong vòng tròn riêng -->
        <TextView
            android:id="@+id/tvRankTop"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="bottom|center_horizontal"
            android:background="@drawable/bg_circle_number_1"
            android:gravity="center"
            android:text="1"
            android:textColor="@android:color/black"
            android:textStyle="bold"
            android:textSize="13sp"
            android:elevation="2dp"
            android:layout_marginBottom="-1dp" />
    </FrameLayout>

    <!-- Tên người chơi -->
    <TextView
        android:id="@+id/tvNameTop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TheHanoiEnjoyer"
        android:textColor="@android:color/white"
        android:textStyle="bold"
        android:textSize="14sp"
        android:layout_marginTop="10dp"
        android:gravity="center"/>

    <!-- Điểm + icon -->
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:layout_marginTop="4dp">

        <ImageView
            android:id="@+id/imgIconScore"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_point_user" />

        <TextView
            android:id="@+id/tvScoreTop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1234"
            android:textColor="@android:color/white"
            android:textSize="13sp"
            android:layout_marginStart="4dp"/>
    </LinearLayout>
</LinearLayout>
