<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/exploreContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/bottomSheetExplore"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginBottom="100dp"
        android:background="@drawable/bg_bottom_sheet"
        android:clickable="true"
        android:focusable="true"
        android:fillViewport="true"
        android:paddingBottom="80dp"
        android:clipToPadding="true"
        app:behavior_hideable="false"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="8dp">

            <!-- Drag handle -->
            <View
                android:layout_width="40dp"
                android:layout_height="4dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_drag_handle" />

            <!-- Header row: icon + title + close -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="30dp">

                <ImageView
                    android:id="@+id/iconExplore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:contentDescription="Explore icon"
                    android:src="@drawable/ic_explore" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Explore"
                    android:textColor="@android:color/white"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <ImageView
                    android:id="@+id/btnCloseExplore"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_close"
                    android:contentDescription="Close" />
            </LinearLayout>

            <!-- CONTENT -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Iconic places -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp"
                    android:layout_marginBottom="12dp"
                    android:text="Iconic places"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvIconicPlaces"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:clipToPadding="false"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

                <!-- Top most visited -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp"
                    android:layout_marginBottom="12dp"
                    android:text="Top most visited places this week"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvTopVisited"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:clipToPadding="false"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

                <!-- Popular near you -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp"
                    android:layout_marginBottom="12dp"
                    android:text="Popular near you"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvPopularNearYou"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:clipToPadding="false"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

                <!-- AI SECTION TITLE -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp"
                    android:layout_marginBottom="12dp"
                    android:text="Exclusive routes just for you"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <!-- AI FORM CARD -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardAiRoute"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardUseCompatPadding="true"
                    app:cardBackgroundColor="@color/explore_card_bg"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:id="@+id/tvAiTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="AI-suggested routes"
                            android:textStyle="bold"
                            android:textSize="16sp"
                            android:textColor="@color/explore_text_primary"
                            android:paddingBottom="8dp" />

                        <!-- Travel date -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Travel date (yyyy-MM-dd)"
                            app:boxBackgroundMode="outline"
                            app:boxBackgroundColor="@color/explore_card_bg"
                            app:boxStrokeColor="@android:color/white"
                            app:hintTextColor="@color/explore_text_hint">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/edtTravelDate"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="@color/explore_text_primary"
                                android:textColorHint="@color/explore_text_hint" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Duration days -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:hint="Duration (days)"
                            app:boxBackgroundMode="outline"
                            app:boxBackgroundColor="@color/explore_card_bg"
                            app:boxStrokeColor="@android:color/white"
                            app:hintTextColor="@color/explore_text_hint">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/edtDurationDays"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="number"
                                android:textColor="@color/explore_text_primary"
                                android:textColorHint="@color/explore_text_hint" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Budget -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:hint="Budget (optional)"
                            app:boxBackgroundMode="outline"
                            app:boxBackgroundColor="@color/explore_card_bg"
                            app:boxStrokeColor="@android:color/white"
                            app:hintTextColor="@color/explore_text_hint">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/edtBudget"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="number"
                                android:textColor="@color/explore_text_primary"
                                android:textColorHint="@color/explore_text_hint" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Interests -->
                        <TextView
                            android:id="@+id/tvInterestsLabel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Interests"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:textColor="@color/explore_text_primary" />

                        <!-- 2 rows of checkboxes to avoid wrapping text -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginTop="4dp">

                            <!-- Row 1: Cuisine + Culture -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <CheckBox
                                    android:id="@+id/cbCuisine"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Cuisine"
                                    android:textColor="@color/explore_text_primary" />

                                <CheckBox
                                    android:id="@+id/cbCulture"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Culture"
                                    android:textColor="@color/explore_text_primary" />
                            </LinearLayout>

                            <!-- Row 2: Entertaining + Iconic -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginTop="4dp">

                                <CheckBox
                                    android:id="@+id/cbEntertaining"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Entertaining"
                                    android:textColor="@color/explore_text_primary" />

                                <CheckBox
                                    android:id="@+id/cbIconic"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Iconic"
                                    android:textColor="@color/explore_text_primary" />
                            </LinearLayout>
                        </LinearLayout>


                        <!-- Button + loading -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp">

                            <Button
                                android:id="@+id/btnSuggestRoute"
                                android:layout_width="match_parent"
                                android:layout_height="44dp"
                                android:backgroundTint="@color/explore_primary"
                                android:text="Generate routes"
                                android:textAllCaps="false"
                                android:textColor="@android:color/white"
                                android:textSize="14sp" />

                            <ProgressBar
                                android:id="@+id/progressBarAiRoute"
                                style="?android:attr/progressBarStyleSmall"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_centerInParent="true"
                                android:visibility="gone" />
                        </RelativeLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- List of suggested routes -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvSuggestedRoutes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp"
                    android:layout_marginBottom="16dp"
                    android:nestedScrollingEnabled="false"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
