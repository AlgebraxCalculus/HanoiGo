<?xml version="1.0" encoding="utf-8"?>
<!-- Layout chính - nên đặt trong activity_main.xml hoặc fragment -->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:backgroundTint="@android:color/transparent">

    <!-- Nội dung chính của app ở đây -->
    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/footerContainer"
        android:layout_marginBottom="-90dp" />

    <!-- Footer bar - CỐ ĐỊNH Ở ĐÁY -->
    <FrameLayout
        android:id="@+id/footerContainer"
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:layout_alignParentBottom="true">

        <!-- View nền sóng -->
        <ImageView
            android:id="@+id/footerWave"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitXY"
            android:src="@drawable/wave_footer"
            />

        <!-- Footer nội dung trên nền sóng -->
        <LinearLayout
            android:id="@+id/footerBar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="0dp"
            android:paddingBottom="0dp"
            android:elevation="8dp">

            <!-- Nút Homepage -->
            <LinearLayout
                android:id="@+id/btnHomepage"
                android:layout_width="0dp"
                android:layout_height="78dp"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="35dp"
                    android:layout_height="35dp"
                    android:contentDescription="Homepage"
                    android:src="@drawable/ic_home"
                    app:tint="#FFFFFF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Homepage"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Khoảng trống giữa -->
            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1" />

            <!-- Nút Personal -->
            <LinearLayout
                android:id="@+id/btnPersonal"
                android:layout_width="0dp"
                android:layout_height="78dp"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="35dp"
                    android:layout_height="35dp"
                    android:contentDescription="Personal"
                    android:src="@drawable/ic_personal"
                    app:tint="#FFFFFF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Personal"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>


    <!-- Nút Map nổi với Glow Effect - HOÀN TOÀN ĐỘC LẬP -->
    <FrameLayout
        android:id="@+id/btnMapFloatContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="26dp"
        android:translationZ="16dp">

        <!-- Background với glow effect -->
        <View
            android:layout_width="95dp"
            android:layout_height="95dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_map_button_glow"/>

        <!-- Button chính -->
        <androidx.cardview.widget.CardView
            android:id="@+id/btnMapFloat"
            android:layout_width="85dp"
            android:layout_height="64dp"
            android:layout_gravity="center"
            android:clickable="true"
            android:elevation="16dp"
            android:focusable="true"
            app:cardBackgroundColor="#001A2E"
            app:cardCornerRadius="50dp"
            app:cardElevation="0dp">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:contentDescription="Map"
                android:src="@drawable/ic_map"
                app:tint="#FFFFFF" />
        </androidx.cardview.widget.CardView>

    </FrameLayout>

</RelativeLayout>
